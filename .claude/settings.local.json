{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Skill(update-config)",
      "Bash(curl *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(npm install *)",
      "Bash(npx kill-port *)",
      "Bash(git log *)",
      "Bash(git cherry-pick *)",
      "Bash(git commit *)",
      "Bash(npx tsc *)",
      "Bash(git add *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -o /dev/null http://localhost:3000 || npm run dev",
            "statusMessage": "Starting dev server...",
            "async": true
          }
        ]
      }
    ]
  }
}
